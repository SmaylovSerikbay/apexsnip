# HTTPS RPC (Helius / Alchemy / QuickNode — mainnet-beta)
RPC_URL=https://mainnet.helius-rpc.com/?api-key=3ad7a6c3-3dc3-495d-bd06-fd5d37fb5ea0

# WebSocket к тому же провайдеру (часто отдельный URL в кабинете Helius)
WSS_URL=wss://mainnet.helius-rpc.com/?api-key=3ad7a6c3-3dc3-495d-bd06-fd5d37fb5ea0

# Опционально: program id для Pump.fun и Raydium CP-Swap (по умолчанию — официальные mainnet из документации)
# PUMP_PROGRAM_ID=
# RAYDIUM_CPMM_PROGRAM_ID=

# Base58 приватный ключ (нужен только при IS_SIMULATION=false в main.go)
PRIVATE_KEY=

# WhatsApp (whatsmeow): E.164 без +; сессия в session.db. Пусто = уведомления отключены.
WHATSAPP_PHONE_E164=77085446945

# Оценка ликвидности пула (грубо): цена SOL в USD и минимум «видимой» ликвидности по WSOL/USDC/USDT ногам.
# REF_SOL_USD=200
# MIN_LIQUIDITY_USD=3000

# Опционально: Jito Block Engine (в коде bundle не отправляется — при наличии переменной пишется подсказка в лог)
